# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# OS files
.DS_Store
Thumbs.db

# Dữ liệu (raw giữ nguyên ignore vì có thể chứa dữ liệu nhạy cảm)
# data/processed/ và data/features/ đã được include để share kết quả

# Model binary (Nặng, không nên upload)
models/*.pkl
models/*.joblib

# Kết quả (Tùy chọn, thường ignore để mỗi lần chạy repo mới sạch)
results/figures/*.png
results/metrics/*.csv

# Logs
logs/*.log
*.log

# Môi trường ảo
venv/
.env
.vscode/
.idea/
